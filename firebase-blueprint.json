{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Atomic Habits Workbook.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's Firebase Auth UID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "identityStatement": { "type": "string", "description": "The identity the user wants to embody (e.g., 'I am the type of person who never misses a workout')." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit the user is tracking or building.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["good", "bad"] },
        "cue": { "type": "string", "description": "1st Law: Make it obvious. What is the trigger?" },
        "craving": { "type": "string", "description": "2nd Law: Make it attractive. What is the motivation?" },
        "response": { "type": "string", "description": "3rd Law: Make it easy. What is the action?" },
        "reward": { "type": "string", "description": "4th Law: Make it satisfying. What is the reward?" },
        "implementationIntention": { "type": "string", "description": "I will [BEHAVIOR] at [TIME] in [LOCATION]." },
        "habitStacking": { "type": "string", "description": "After [CURRENT HABIT], I will [NEW HABIT]." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "createdAt"]
    },
    "ScorecardItem": {
      "title": "ScorecardItem",
      "description": "An item on the user's habit scorecard.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "rating": { "type": "string", "enum": ["+", "-", "="] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "rating", "createdAt"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "A user's answer to a workbook prompt.",
      "type": "object",
      "properties": {
        "promptId": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["promptId", "content", "updatedAt"]
    },
    "DailyPlan": {
      "title": "DailyPlan",
      "description": "A daily job hunt plan generated by AI.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "focus": { "type": "string" },
        "tasks": { "type": "array", "items": { "type": "string" } },
        "skillTask": { "type": "string" },
        "jobTask": { "type": "string" },
        "reflectionPrompt": { "type": "string" },
        "reflectionAnswer": { "type": "string" },
        "completed": { "type": "boolean" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "focus", "tasks", "skillTask", "jobTask", "reflectionPrompt", "completed", "createdAt"]
    },
    "Completion": {
      "title": "Completion",
      "description": "A daily habit completion record.",
      "type": "object",
      "properties": {
        "habitId": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["habitId", "date", "createdAt"]
    },
    "JobApplication": {
      "title": "JobApplication",
      "description": "A tracked job application.",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["Bookmarked", "Applied", "Interviewing", "Offer", "Rejected"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["company", "role", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": { "$ref": "#/entities/Habit" },
      "description": "User's habits."
    },
    "/users/{userId}/scorecards/{scorecardId}": {
      "schema": { "$ref": "#/entities/ScorecardItem" },
      "description": "User's habit scorecard items."
    },
    "/users/{userId}/reflections/{reflectionId}": {
      "schema": { "$ref": "#/entities/Reflection" },
      "description": "User's reflections and journal entries."
    },
    "/users/{userId}/dailyPlans/{planId}": {
      "schema": { "$ref": "#/entities/DailyPlan" },
      "description": "User's daily job hunt plans."
    },
    "/users/{userId}/completions/{completionId}": {
      "schema": { "$ref": "#/entities/Completion" },
      "description": "User's habit completions."
    },
    "/users/{userId}/jobs/{jobId}": {
      "schema": { "$ref": "#/entities/JobApplication" },
      "description": "User's job applications."
    }
  }
}
